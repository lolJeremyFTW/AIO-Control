# Copy to .env.local for local development. Never commit .env.local.

# ── Supabase (self-hosted on VPS or local container) ─────────────────────────
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key. SERVER ONLY — never imported from client components.
# Used for migrations, the audit-log trigger, and trusted server actions.
SUPABASE_SERVICE_ROLE_KEY=

# Direct Postgres connection (used by Drizzle for migrations and server queries).
DATABASE_URL=postgres://postgres:postgres@localhost:54322/postgres

# Symmetric key for pgcrypto (encrypts agent_secrets, bearer tokens, etc.).
# Generate once with: openssl rand -base64 32
AGENT_SECRET_KEY=

# ── Phase 3+ (provider keys) ─────────────────────────────────────────────────
# Optional during phase 0/1 — add when wiring providers.
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
MINIMAX_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
OPENCLAW_BASE_URL=
HERMES_BASE_URL=

# ── Phase 4 scheduling callbacks ─────────────────────────────────────────────
# Shared secret Claude Routines must echo back when posting run results.
ROUTINE_CALLBACK_SECRET=

# ── Phase 6 deployment ───────────────────────────────────────────────────────
# Empty for local dev; set to "/aio" on the VPS so basePath kicks in.
BASE_PATH=
