{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"],
      "env": [
        "BASE_PATH",
        "NEXT_RUNTIME",
        "NEXT_PHASE",
        "GIT_COMMIT_SHA",
        "BUILD_TIME",
        "AGENT_SECRET_KEY",
        "AIO_CRON_SCHEDULER_ENABLED",
        "TELEGRAM_WEBHOOK_SECRET",
        "SLACK_BOT_TOKEN",
        "SLACK_SIGNING_SECRET",
        "DISCORD_BOT_TOKEN",
        "DISCORD_PUBLIC_KEY",
        "AIO_ALLOW_PRIVATE_INTEGRATION_URLS",
        "AIO_FILE_BROWSER_ROOT",
        "AIO_BASH_APPROVAL_TOKEN",
        "AIO_MCP_ALLOW_READ_SECRET",
        "AIO_TRANSLATION_PROVIDER",
        "AIO_TRANSLATION_MODEL",
        "AIO_TRANSLATION_OLLAMA_MODEL",
        "OUTREACH_PUBLIC_ORIGIN",
        "OUTREACH_PIPELINE_SCHEDULER_ENABLED",
        "OUTREACH_PIPELINE_TICK_MS",
        "OLLAMA_BASE_URL"
      ]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
