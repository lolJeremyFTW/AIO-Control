{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "globalEnv": [
    "AGENT_RUN_TIMEOUT_MS",
    "AIO_DASHBOARD_ORIGIN",
    "AIO_WORKSPACE_ID",
    "ANTHROPIC_API_KEY",
    "CRON_QUEUE_INTER_RUN_DELAY_MS",
    "CRON_QUEUE_MAX_AGE_MS",
    "CRON_QUEUE_MAX_PER_WORKSPACE",
    "DISCORD_PUBLIC_KEY",
    "ENABLE_OAUTH_GITHUB",
    "ENABLE_OAUTH_GOOGLE",
    "HEALTH_MAX_QUEUED_RUNS",
    "HEALTH_MAX_RUNNING_RUNS",
    "HEALTH_STALE_RUN_MINUTES",
    "HERMES_BIN",
    "MINIMAX_API_KEY",
    "MOLLIE_API_KEY",
    "OPENAI_CODEX_AUTHORIZE_URL",
    "OPENAI_CODEX_CLIENT_ID",
    "OPENAI_CODEX_SCOPES",
    "OPENAI_CODEX_TOKEN_URL",
    "OPENCLAW_BIN",
    "OPENCLAW_MODEL_CATALOG_TIMEOUT_MS",
    "OPENCLAW_WORKSPACE_DIR",
    "OUTREACH_IP_SALT",
    "RETRY_SAME_AGENT_DELAY_MS",
    "RETRY_SWEEP_PER_TICK",
    "RETRY_SWEEP_SECRET",
    "ROUTINE_CALLBACK_SECRET",
    "SMTP_FROM",
    "SMTP_HOST",
    "SMTP_PASS",
    "SMTP_PORT",
    "SMTP_USER",
    "STRIPE_SECRET_KEY",
    "STARTUP_ORPHAN_DELAY_MS",
    "STRIPE_WEBHOOK_SECRET",
    "SUPABASE_SERVICE_ROLE_KEY",
    "VAPID_PRIVATE_KEY",
    "VAPID_PUBLIC_KEY",
    "VAPID_SUBJECT",
    "WEATHER_CITY",
    "WEATHER_LATITUDE",
    "WEATHER_LONGITUDE",
    "WORKSPACE_CONCURRENCY"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"],
      "env": [
        "BASE_PATH",
        "NEXT_RUNTIME",
        "NEXT_PHASE",
        "GIT_COMMIT_SHA",
        "BUILD_TIME",
        "AGENT_SECRET_KEY",
        "AIO_CRON_SCHEDULER_ENABLED",
        "TELEGRAM_WEBHOOK_SECRET",
        "SLACK_BOT_TOKEN",
        "SLACK_SIGNING_SECRET",
        "DISCORD_BOT_TOKEN",
        "DISCORD_PUBLIC_KEY",
        "AIO_ALLOW_PRIVATE_INTEGRATION_URLS",
        "AIO_FILE_BROWSER_ROOT",
        "AIO_BASH_APPROVAL_TOKEN",
        "AIO_MCP_ALLOW_READ_SECRET",
        "AIO_TRANSLATION_PROVIDER",
        "AIO_TRANSLATION_MODEL",
        "AIO_TRANSLATION_OLLAMA_MODEL",
        "OUTREACH_PUBLIC_ORIGIN",
        "OUTREACH_PIPELINE_SCHEDULER_ENABLED",
        "OUTREACH_PIPELINE_TICK_MS",
        "OLLAMA_BASE_URL"
      ]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
